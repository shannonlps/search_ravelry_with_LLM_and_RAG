# Copy this to .env and fill in your values
# Never commit .env to git

# Anthropic API key (used by the app at runtime — users can also supply their own in the UI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ravelry API credentials — DEDICATED INGEST APP (separate from your main app credentials)
# Create a second app at https://www.ravelry.com/pro/developer
INGEST_RAVELRY_USERNAME=your_ingest_api_username
INGEST_RAVELRY_PASSWORD=your_ingest_api_password
